{
  "version": "1.0.0",
  "api": {
    "endpoint": "https://api.openai.com/v1",
    "api_key": "",
    "model": "gpt-4o",
    "timeout": 30,
    "max_retries": 3
  },
  "hotkeys": {
    "screenshot": "ctrl+shift+a",
    "paste": "ctrl+shift+v"
  },
  "history": {
    "retention_days": 7,
    "max_records": 1000
  },
  "update": {
    "auto_check": true,
    "check_url": "https://api.github.com/repos/YOUR_USER/texpaste/releases/latest"
  },
  "pandoc": {
    "executable": "pandoc"
  },
  "appearance": {
    "theme": "system"
  },
  "templates": {
    "current": "智能识别",
    "custom": []
  },
  "notifications": {
    "recognition_success": true,
    "paste_success": false,
    "error": true
  }
}
